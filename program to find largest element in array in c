#include <stdio.h>

int main() {
    int arr[] = {12, 45, 7, 92, 31};
    int length = sizeof(arr) / sizeof(arr[0]);
    int max = arr[0];

    for (int i = 1; i < length; i++) {
        if (arr[i] > max) {
            max = arr[i];
        }
    }

    printf("Largest element in the array is: %d\n", max);
    return 0;
}
