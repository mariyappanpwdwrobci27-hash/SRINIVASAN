#include <stdio.h>
int main() 
{
int n=5,c_yellow=10,c_white=10,tc,p[10],i=0,cp1=0,cp2=0;
printf("enter for each person\n 0.none 1.module1 2.module2 3.both/n");
for(i=0;i<n;i++)
scanf("%d",&p[i]);
for(i=0;i<n;i++)
{
    if(p[i]==1)
    cp1++;
    else if(p[i]==2)
    cp2++;
    else if(p[i]==3)
    {
        cp1++;
        cp2++;
    }
    else
    continue;
}
tc=(cp1*c_yellow)+(cp2*c_white);
printf("total cost %d",tc);
return 0;
}
