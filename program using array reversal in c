#include <stdio.h>
#include <stdlib.h>

int main() {
    int n;
    
    // Read the size of the array
    if (scanf("%d", &n) != 1) return 1;

    // Dynamically allocate memory
    int *arr = (int*)malloc(n * sizeof(int));
    if (arr == NULL) return 1;

    // Read the array elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // In-place reversal logic
    for (int i = 0; i < n / 2; i++) {
        int temp = arr[i];
        arr[i] = arr[n - 1 - i];
        arr[n - 1 - i] = temp;
    }

    // Print the reversed array
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    // Free memory
    free(arr);

    return 0;
}
