#include <stdio.h>

#define MAX_LEN 100

int main() {
    char ch;
    char s[MAX_LEN];
    char sentence[MAX_LEN];

    scanf("%c", &ch);
    scanf("%s", s);
    scanf("\n");
    scanf("%[^\n]%*c", sentence);

    printf("%c\n", ch);
    printf("%s\n", s);
    printf("%s\n", sentence);

    return 0;
}
