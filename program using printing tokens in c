#include <stdio.h>
#include <string.h>
#include <stdlib.h>

int main() {
    char *s;
    s = malloc(1024 * sizeof(char));
    
    // Read the entire line of input
    scanf("%[^\n]", s);
    s = realloc(s, strlen(s) + 1);
    
    // Iterate through the string and replace spaces with newlines
    for (int i = 0; s[i] != '\0'; i++) {
        if (s[i] == ' ') {
            printf("\n");
        } else {
            printf("%c", s[i]);
        }
    }
    printf("\n");

    free(s);
    return 0;
}
