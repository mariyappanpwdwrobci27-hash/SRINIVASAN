#include <stdio.h>
int main() 
{
int n=5,c_green=2,c_purple=3,tc,p[10],i=0,cp1=0,cp2=0;
printf("enter for each person\n 0.none 1.problem1 solved 2.problem2 solved 3.both/n");
for(i=0;i<n;i++)
scanf("%d",&p[i]);
for(i=0;i<n;i++);
{
    if(p[i]==1)
    cp1++;
    else if(p[i]==2)
    cp2++;
    else if(p[i]==3)
    {
        cp1++;
        cp2++;
    }
    else
    continue;
}
tc=(cp1*c_green)+(cp2*c_purple);
printf("total cost %d",tc);
return 0;
}
